// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum AssetType {
  SERVER
  STORAGE
  SWITCH
  SP
  NETWORK
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DECOMMISSIONED
}

enum VmPowerState {
  RUNNING
  STOPPED
  SUSPENDED
}

enum VmEnvironment {
  PROD
  TEST
  UAT
}

enum VmDiscoveryState {
  NEEDS_CONTEXT
  READY_TO_PROMOTE
  DRIFTED
  ARCHIVED
}

enum VmLifecycleState {
  DRAFT
  ACTIVE
  DELETED_IN_VCENTER
  ARCHIVED
}

enum VmCriticality {
  MISSION_CRITICAL
  BUSINESS_CRITICAL
  STANDARD
}

enum AuditAction {
  VIEW_PASSWORD
  COPY_PASSWORD
  LOGIN
  CREATE_USER
  UPDATE_USER_ROLE
  RESET_USER_PASSWORD
  CHANGE_OWN_PASSWORD
  CREATE_ASSET
  UPDATE_ASSET
  DELETE_ASSET
  CREATE_CREDENTIAL
  UPDATE_CREDENTIAL
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  displayName  String
  avatarSeed   String
  avatarImage  String?
  email        String?  @unique
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assets              Asset[]
  databaseInventories DatabaseInventory[]
  vmVCenterSources    VmVCenterSource[]
  vmDiscoveries       VmDiscovery[]
  vmInventories       VmInventory[]
  auditLogs           AuditLog[]
}

model IPAllocation {
  id         String  @id @default(uuid())
  address    String // e.g. 192.168.1.50
  type       String? // e.g. Management, VIP, Backup, Data, IPMI, Host, Service Processor
  nodeLabel  String?
  manageType String? // e.g. WEB, SSH, API
  version    String? // e.g. iLO 2.81, ESXi 8.0.3
  assetId    String
  asset      Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([address, assetId])
}

model Asset {
  id             String      @id @default(uuid())
  assetId        String?     @unique // e.g., '6303-0003'
  name           String
  type           AssetType
  environment    String? // e.g., 'PROD', 'UAT', 'DEV'
  location       String? // e.g., 'DC'
  rack           String? // e.g., '1C-04'
  osVersion      String? // e.g., 'Fabric OS: v8.2.1c'
  manageType     String? // e.g., 'WEB/SSH'
  brandModel     String? // e.g., 'HPE StoreFabric SN3600B'
  sn             String? // Serial Number
  customMetadata Json? // Flexible JSON structure for other specs
  status         AssetStatus @default(ACTIVE)

  // Financial & Info
  owner              String?
  department         String?
  purchaseDate       DateTime?
  warrantyExpiration DateTime?
  vendor             String?
  dependencies       String?

  // Hierarchical Relationship (Parent-Child)
  parentId String?
  parent   Asset?  @relation("AssetHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Asset[] @relation("AssetHierarchy")

  // IP Management
  ipAllocations IPAllocation[]

  createdByUserId String
  createdByUser   User   @relation(fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patchInfo   PatchInfo?
  credentials Credential[]
}

model PatchInfo {
  id      String @id @default(uuid())
  assetId String @unique
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  currentVersion  String?
  latestVersion   String?
  eolDate         DateTime?
  lastPatchedDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Credential {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  username          String
  encryptedPassword String
  type              String? // e.g. 'IPMI', 'OS', 'SSH', 'WEB'
  nodeLabel         String?
  manageType        String? // e.g. WEB, SSH, API
  version           String? // e.g. iLO 2.81, ESXi 8.0.3

  lastChangedDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  action    AuditAction
  targetId  String? // ID of the asset or credential interacted with
  ipAddress String?
  details   String? // Optional JSON or text details

  timestamp DateTime @default(now())
}

model DatabaseInventory {
  id                String   @id @default(uuid())
  name              String
  engine            String
  version           String?
  environment       String?
  host              String
  ipAddress         String
  port              String?
  serviceName       String?
  owner             String?
  backupPolicy      String?
  replication       String?
  linkedApps        String[]
  maintenanceWindow String?
  status            String?
  note              String?

  createdByUserId String
  createdByUser   User   @relation(fields: [createdByUserId], references: [id])

  accounts  DatabaseAccount[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model DatabaseAccount {
  id                  String            @id @default(uuid())
  databaseInventoryId String
  databaseInventory   DatabaseInventory @relation(fields: [databaseInventoryId], references: [id], onDelete: Cascade)

  username          String
  role              String?
  encryptedPassword String
  privileges        String[]
  note              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VmVCenterSource {
  id                String    @id @default(uuid())
  name              String    @unique
  endpoint          String
  version           String
  username          String?
  encryptedPassword String?
  syncInterval      String
  status            String
  lastSyncAt        DateTime?
  notes             String?

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])

  discoveries VmDiscovery[]
  inventories VmInventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VmDiscovery {
  id                   String           @id @default(uuid())
  name                 String
  systemName           String?
  moid                 String           @unique
  sourceId             String
  source               VmVCenterSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cluster              String
  clusterResolution    String           @default("UNKNOWN")
  host                 String
  hostResolution       String           @default("UNKNOWN")
  computerName         String?
  guestOs              String
  primaryIp            String
  cpuCores             Int
  memoryGb             Int
  storageGb            Int
  disks                Json?
  networkLabel         String
  powerState           VmPowerState
  state                VmDiscoveryState
  completeness         Int
  missingFields        String[]
  lastSeenAt           DateTime
  tags                 String[]
  guestAccountsCount   Int              @default(0)
  owner                String?
  environment          VmEnvironment?
  businessUnit         String?
  slaTier              String?
  serviceRole          String?
  criticality          VmCriticality?
  description          String?
  notes                String?
  suggestedOwner       String?
  suggestedEnvironment VmEnvironment?
  suggestedServiceRole String?
  suggestedCriticality VmCriticality?

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])

  guestAccounts VmGuestAccount[]
  inventory     VmInventory?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VmInventory {
  id             String           @id @default(uuid())
  discoveryId    String?          @unique
  discovery      VmDiscovery?     @relation(fields: [discoveryId], references: [id], onDelete: SetNull)
  sourceId       String?
  source         VmVCenterSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  name           String
  systemName     String
  moid           String           @unique
  environment    VmEnvironment
  cluster        String
  clusterResolution String         @default("UNKNOWN")
  host           String
  hostResolution String            @default("UNKNOWN")
  computerName   String?
  guestOs        String
  primaryIp      String
  cpuCores       Int
  memoryGb       Int
  storageGb      Int
  disks          Json?
  networkLabel   String
  powerState     VmPowerState
  lifecycleState VmLifecycleState
  syncState      String
  owner          String
  businessUnit   String
  slaTier        String
  serviceRole    String
  criticality    VmCriticality
  description    String
  tags           String[]
  lastSyncAt     DateTime
  syncedFields   String[]
  managedFields  String[]
  notes          String

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])

  guestAccounts VmGuestAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VmGuestAccount {
  id                String       @id @default(uuid())
  username          String
  encryptedPassword String
  accessMethod      String
  role              String
  note              String?
  discoveryId       String?
  discovery         VmDiscovery? @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  inventoryId       String?
  inventory         VmInventory? @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
