# Handle line endings automatically for files detected as text 
# and leave binary files untouched.
* text=auto

# Standardize on LF for all source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.prisma text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Explicitly declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
